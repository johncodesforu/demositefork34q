rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'mamidiabhyun@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.price is number && data.price >= 0
        && data.category is string
        && data.images is list && data.images.size() > 0
        && (data.keys().hasAll(['name', 'price', 'category', 'images']))
        && (data.keys().size() >= 4);
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid
        && data.total is number && data.total >= 0
        && data.status is string && data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled']
        && data.items is list && data.items.size() > 0
        && data.createdAt == request.time;
    }

    // --- Collection Rules ---

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidOrder(incoming());
      allow update: if isAdmin() || (
        isOwner(existing().userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status == 'cancelled' &&
        existing().status == 'pending'
      );
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && incoming().keys().size() <= 10;
      allow update: if isOwner(userId) && !incoming().diff(existing()).affectedKeys().hasAny(['uid', 'email', 'role']);
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
    }
  }
}
