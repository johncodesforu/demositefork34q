{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A marketplace product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "inventory": { "type": "number" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "variants": { "type": "array" },
        "specs": { "type": "object" },
        "featured": { "type": "boolean" },
        "trending": { "type": "boolean" }
      },
      "required": ["name", "price", "images", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "object" },
        "trackingNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of all products"
    },
    "orders": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "users": {
      "schema": "object",
      "description": "User profiles and metadata"
    },
    "banners": {
      "schema": "object",
      "description": "Hero banners for the homepage"
    }
  }
}
